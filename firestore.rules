rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ──────────────────────────────────────────────
    // MULTI-COMPANY ROLE HELPER FUNCTIONS
    // ──────────────────────────────────────────────

    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Path to the membership document in a given company
    function memberPath(companyId) {
      return /databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid);
    }
    
    // Check if user is active member of a company
    function isActiveCompanyMember(companyId) {
      return isSignedIn()
        && exists(memberPath(companyId))
        && get(memberPath(companyId)).data.status == "active";
    }
    
    // Resolve user's role in a company
    function getCompanyMember(companyId) {
      return get(memberPath(companyId)).data;
    }
    
    // Specific role checkers
    function isCompanyOwner(companyId) {
      return isActiveCompanyMember(companyId)
        && getCompanyMember(companyId).role == "owner";
    }

    function isCompanyAdmin(companyId) {
      return isActiveCompanyMember(companyId)
        && getCompanyMember(companyId).role in ["owner", "admin"];
    }

    function isCompanyManager(companyId) {
      return isActiveCompanyMember(companyId)
        && getCompanyMember(companyId).role in ["owner", "admin", "manager"];
    }

    function isCompanyDispatcher(companyId) {
      return isActiveCompanyMember(companyId)
        && getCompanyMember(companyId).role in ["owner", "admin", "manager", "dispatcher"];
    }

    function isCompanyStaff(companyId) {
      return isActiveCompanyMember(companyId)
        && getCompanyMember(companyId).role in ["owner", "admin", "manager", "designer", "sales", "accountant", "dispatcher", "driver"];
    }

    // Standard business document rules matching companyId
    function canReadCompanyDoc() {
      return isActiveCompanyMember(resource.data.companyId);
    }

    function canCreateCompanyDoc() {
      return request.resource.data.companyId is string
        && isActiveCompanyMember(request.resource.data.companyId);
    }

    function canUpdateCompanyDoc() {
      return isActiveCompanyMember(resource.data.companyId)
        && request.resource.data.companyId == resource.data.companyId;
    }

    function canDeleteCompanyDoc() {
      return isCompanyAdmin(resource.data.companyId);
    }

    // ──────────────────────────────────────────────
    // GUEST CHECKOUT SAFETY (Locked to DEFAULT_COMPANY)
    // ──────────────────────────────────────────────
    function guestSafeOrderFields() {
      return request.resource.data.keys().hasOnly([
        'customerName', 'customerEmail', 'recipientName', 'recipientPhone',
        'recipientAddress', 'recipientCity', 'recipientState', 'recipientZip',
        'deliveryType', 'deliveryDate', 'senderName', 'senderEmail',
        'cardMessage', 'items', 'subtotal', 'taxes', 'deliveryFee', 'total', 
        'status', 'createdAt', 'id', 'orderNumber', 'orderNumberNormalized', 
        'senderEmailNormalized', 'customerId', 'paymentStatus', 'glPostingStatus',
        'companyId'
      ])
      && !request.resource.data.keys().hasAny([
        'internalNotes',
        'auditTrail',
        'financeStatus',
        'glPosted',
        'assignedStaffId'
      ]);
    }

    function isValidGuestOrderCreate() {
      return request.auth == null
        && request.resource.data.companyId == "DEFAULT_COMPANY"
        && request.resource.data.status == 'confirmed'
        && request.resource.data.paymentStatus == 'paid'
        && request.resource.data.glPostingStatus == 'unposted'
        && request.resource.data.customerId == 'guest'
        && guestSafeOrderFields();
    }

    function publicTrackingFields() {
      return [
        'orderNumber', 'orderNumberNormalized', 'senderEmailNormalized',
        'status', 'deliveryDate', 'recipientFirstName',
        'city', 'state', 'itemsSummary', 'timeline', 'updatedAt',
        'deliveryWindow', 'trackingMessage', 'companyId'
      ];
    }

    function isValidPublicTrackingCreate(trackingId) {
      let data = request.resource.data;
      return data.keys().hasOnly(publicTrackingFields())
        && trackingId == data.orderNumberNormalized + '_' + data.senderEmailNormalized
        && data.orderNumberNormalized is string
        && data.senderEmailNormalized is string
        && data.orderNumber is string
        && data.status == 'placed';
    }

    // ──────────────────────────────────────────────
    // USERS (Bootstrap remains global)
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/companies/DEFAULT_COMPANY/members/$(request.auth.uid)) && get(/databases/$(database)/documents/companies/DEFAULT_COMPANY/members/$(request.auth.uid)).data.role == "owner";
    }

    // ──────────────────────────────────────────────
    // METADATA (Role-claim tracking for first-user bootstrap)
    // ──────────────────────────────────────────────
    match /_metadata/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ──────────────────────────────────────────────
    // SYSTEM SEEDS (Demo data idempotency flags)
    // ──────────────────────────────────────────────
    match /systemSeeds/{seedId} {
      allow read, write: if isSignedIn();
    }

    // ──────────────────────────────────────────────
    // COMPANIES (Core settings and members nested)
    // ──────────────────────────────────────────────
    match /companies/{companyId} {
      allow get: if isSignedIn()
        && (companyId == 'DEFAULT_COMPANY' || isActiveCompanyMember(companyId));
      allow list: if false;
      allow create: if isSignedIn(); // Bootstrapping companies is allowed for signed-in users
      allow update: if isCompanyAdmin(companyId);
      allow delete: if isCompanyOwner(companyId);

      match /settings/{settingId} {
        allow read: if isActiveCompanyMember(companyId)
          || (isSignedIn() && companyId in ["DEFAULT_COMPANY", "rose-sage", "orchid-lane"]);
        allow write: if isCompanyManager(companyId)
          || (isSignedIn() && companyId in ["DEFAULT_COMPANY", "rose-sage", "orchid-lane"]);
      }

      match /members/{memberUserId} {
        allow read: if (isSignedIn() && request.auth.uid == memberUserId) || isActiveCompanyMember(companyId);
        allow create: if isCompanyAdmin(companyId) || (
          isSignedIn() && 
          request.auth.uid == memberUserId && (
            companyId in ["DEFAULT_COMPANY", "rose-sage", "orchid-lane"] ||
            get(/databases/$(database)/documents/companies/$(companyId)).data.createdBy == request.auth.uid
          )
        );
        allow update: if isCompanyAdmin(companyId) || (
          isSignedIn() && 
          request.auth.uid == memberUserId && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['languagePreference', 'defaultBranchId'])
        );
        allow delete: if isCompanyOwner(companyId);
      }
    }

    // Collection Group rule for members to allow users to query their own memberships
    match /{path=**}/members/{memberUserId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        memberUserId == request.auth.uid
      );
    }

    // ──────────────────────────────────────────────
    // BUSINESS COLLECTIONS (Company scoped)
    // ──────────────────────────────────────────────

    // ORDERS
    match /orders/{orderId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() || isValidGuestOrderCreate();
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }
    
    // JOURNAL ENTRIES
    match /journalEntries/{entryId} {
      allow read: if isActiveCompanyMember(resource.data.companyId) && isCompanyManager(resource.data.companyId);
      allow create: if canCreateCompanyDoc() && (
        isCompanyStaff(request.resource.data.companyId) || (
          request.auth == null && request.resource.data.companyId == "DEFAULT_COMPANY" && request.resource.data.sourceType in ['order', 'demo_order']
        )
      );
      allow update: if canUpdateCompanyDoc() && isCompanyAdmin(resource.data.companyId)
        && resource.data.status == 'posted'
        && request.resource.data.status == 'reversed'
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['status', 'reversedBy', 'reversedAt', 'reversalEntryId']);
      allow delete: if false;
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if isActiveCompanyMember(resource.data.companyId) && isCompanyManager(resource.data.companyId);
      allow create: if canCreateCompanyDoc() && (
        isCompanyStaff(request.resource.data.companyId) || (
          request.auth == null && request.resource.data.companyId == "DEFAULT_COMPANY" && request.resource.data.action == 'ORDER_STATUS_CHANGE'
        )
      );
      allow update, delete: if false;
    }

    // QA RUNS
    match /qaRuns/{runId} {
      allow read: if isActiveCompanyMember(resource.data.companyId) && isCompanyManager(resource.data.companyId);
      allow create: if canCreateCompanyDoc() && isCompanyAdmin(request.resource.data.companyId);
      allow update, delete: if false;
    }

    // PRODUCTS (Scoped to products_admin)
    match /products_admin/{productId} {
      allow read: if canReadCompanyDoc() || (
        resource.data.companyId == "DEFAULT_COMPANY" && resource.data.productStatus == "active"
      );
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }

    // CUSTOMERS
    match /customers/{customerId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }

    // DELIVERIES
    match /deliveries/{deliveryId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && (getCompanyMember(request.resource.data.companyId).role in ["owner", "admin", "manager", "dispatcher", "sales"]);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }

    // DELIVERY QUOTES
    match /deliveryQuotes/{quoteId} {
      allow read: if canReadCompanyDoc() && (getCompanyMember(resource.data.companyId).role in ["owner", "admin", "manager", "dispatcher", "sales"]);
      allow create: if canCreateCompanyDoc() && (getCompanyMember(request.resource.data.companyId).role in ["owner", "admin", "manager", "dispatcher", "sales"]);
      allow update: if canUpdateCompanyDoc() && (getCompanyMember(resource.data.companyId).role in ["owner", "admin", "manager", "dispatcher", "sales"]);
      allow delete: if canDeleteCompanyDoc();
    }

    // DELIVERY EVENTS
    match /deliveryEvents/{eventId} {
      allow read: if canReadCompanyDoc() && (getCompanyMember(resource.data.companyId).role in ["owner", "admin", "manager", "dispatcher"]);
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update, delete: if false;
    }

    // DELIVERY PROVIDER CONFIGS
    match /deliveryProviderConfigs/{configId} {
      allow read: if canReadCompanyDoc() && (getCompanyMember(resource.data.companyId).role in ["owner", "admin", "manager", "dispatcher"]);
      allow create, update: if canCreateCompanyDoc() && (getCompanyMember(request.resource.data.companyId).role in ["owner", "admin", "manager"]);
      allow delete: if canDeleteCompanyDoc() && (getCompanyMember(resource.data.companyId).role in ["owner", "admin", "manager"]);
    }

    // PUBLIC DELIVERY TRACKING
    match /publicDeliveryTracking/{trackingToken} {
      allow get: if true;
      allow list: if false;
      allow create, update: if (request.auth != null && isCompanyStaff(request.resource.data.companyId));
      allow delete: if (request.auth != null && isCompanyAdmin(request.resource.data.companyId));
    }

    // INVENTORY
    match /inventory/{itemId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyManager(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyManager(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc() && isCompanyOwner(resource.data.companyId);
    }

    // PAYMENTS, STATEMENTS, NOTES
    match /payments/{paymentId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }
    match /customerStatements/{statementId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }
    match /collectionNotes/{noteId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }

    // PURCHASING & PAYABLES (Sprint 1C & 1D collections)
    match /vendors/{vendorId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }
    match /purchaseOrders/{poId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }
    match /inventoryReceipts/{receiptId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update, delete: if false;
    }
    match /vendorBills/{billId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if false;
    }
    match /vendorPayments/{paymentId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if false;
    }
    match /inventoryTransactions/{txId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update, delete: if false;
    }
    match /sequences/{seqId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if false;
    }
    match /branches/{branchId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId);
      allow delete: if canDeleteCompanyDoc();
    }

    // PUBLIC ORDER TRACKING
    match /publicOrderTracking/{trackingId} {
      allow get: if true;
      allow list: if false;
      allow create: if (request.auth != null && isCompanyStaff(request.resource.data.companyId)) || (
        request.auth == null && request.resource.data.companyId == "DEFAULT_COMPANY" && isValidPublicTrackingCreate(trackingId)
      );
      allow update, delete: if isCompanyStaff(resource.data.companyId);
    }

    // SYSTEM SEEDS
    match /systemSeeds/{seedId} {
      allow read, write: if isSignedIn();
    }

    // METADATA
    match /_metadata/roles {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerClaimed == true;
      allow update: if isSignedIn() && resource.data.ownerClaimed == false && request.resource.data.ownerClaimed == true;
    }

    // CHART OF ACCOUNTS
    match /chartOfAccounts/{accountId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(resource.data.companyId) && (
        !('isSystem' in resource.data) || 
        resource.data.isSystem != true || 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'code', 'name', 'type', 'normalBalance', 'isSystem',
          'statementType', 'statementSection', 'reportLineGroup', 'cashFlowCategory', 'displayOrder',
          'isPostingAccount', 'allowManualPosting', 'allowSystemPosting', 'isCashAccount', 'isControlAccount'
        ])
      );
      allow delete: if canDeleteCompanyDoc() && (
        !('isSystem' in resource.data) || 
        resource.data.isSystem != true
      );
    }

    // ──────────────────────────────────────────────
    // SETTINGS (Legacy flat settings, fallback)
    // ──────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ──────────────────────────────────────────────
    // RECONCILIATION & TAX READINESS RULES
    // ──────────────────────────────────────────────
    
    match /reconciliationRuns/{runId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && (getCompanyMember(request.resource.data.companyId).role in ["owner", "admin", "accountant", "manager"]);
      allow update: if canUpdateCompanyDoc() && (getCompanyMember(request.resource.data.companyId).role in ["owner", "admin", "accountant", "manager"]);
      allow delete: if canDeleteCompanyDoc();
    }

    match /reconciliationExceptions/{exceptionId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow update: if canUpdateCompanyDoc() && isCompanyStaff(request.resource.data.companyId);
      allow delete: if false;
    }

    match /reconciliationAdjustments/{adjustmentId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc()
        && isCompanyStaff(request.resource.data.companyId)
        && request.resource.data.status == 'pending_approval'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.proposedJournalLines is list
        && request.resource.data.proposedJournalLines.size() >= 2;
      allow update: if canUpdateCompanyDoc()
        && (getCompanyMember(resource.data.companyId).role in ["owner", "admin", "accountant"])
        && (
          // Transitions
          (resource.data.status == 'pending_approval' && request.resource.data.status == 'posted')
          || (resource.data.status == 'pending_approval' && request.resource.data.status == 'rejected')
          || (resource.data.status in ['draft', 'pending_approval'] && request.resource.data.status == resource.data.status)
        )
        && (resource.data.status != 'posted' && resource.data.status != 'rejected');
      allow delete: if canDeleteCompanyDoc() && resource.data.status == 'draft';
    }

    match /taxReadinessReviews/{reviewId} {
      allow read: if canReadCompanyDoc();
      allow create, update: if canCreateCompanyDoc() && (getCompanyMember(request.resource.data.companyId).role in ["owner", "admin", "accountant"]);
      allow delete: if canDeleteCompanyDoc();
    }

    // CLOSED PERIODS (Period locking after reconciliation approval)
    match /closedPeriods/{periodId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && (getCompanyMember(request.resource.data.companyId).role in ["owner", "admin", "accountant"]);
      allow update, delete: if false; // Immutable once created
    }

    // AUDIT EVIDENCE PACKETS (Immutable compliance snapshots)
    match /auditEvidencePackets/{packetId} {
      allow read: if canReadCompanyDoc();
      allow create: if canCreateCompanyDoc() && (getCompanyMember(request.resource.data.companyId).role in ["owner", "admin", "accountant"]);
      allow update, delete: if false; // Immutable
    }

    // ──────────────────────────────────────────────
    // DEFAULT DENY
    // ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
