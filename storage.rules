rules_version = '2';

// ──────────────────────────────────────────────────────────────────────────
// Firebase Storage is intentionally CLOSED (deny-by-default).
//
// As of this release the application initializes Storage (src/firebase/config.ts)
// but has NO feature that uploads to or reads from it — there are no Storage SDK
// operations anywhere in the codebase. Rather than leave the bucket's rules
// unmanaged/untracked, we deny all access until a scoped feature needs it.
//
// When a real feature is added, REPLACE the catch-all deny below with explicit,
// authenticated, COMPANY-SCOPED paths that mirror the active-membership model in
// firestore.rules. Storage rules can read Firestore via firestore.get/exists,
// e.g.:
//
//   match /companies/{companyId}/{allPaths=**} {
//     allow read, write: if request.auth != null
//       && firestore.exists(
//            /databases/(default)/documents/companies/$(companyId)/members/$(request.auth.uid))
//       && firestore.get(
//            /databases/(default)/documents/companies/$(companyId)/members/$(request.auth.uid)
//          ).data.status == 'active';
//   }
//
// Keep cross-company access denied and never trust client-supplied companyId
// without the membership check above.
// ──────────────────────────────────────────────────────────────────────────
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
