# Firebase Configuration
# These are public keys for the web client. Keep your Firebase secure using Firestore Rules, not by hiding these.
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Note:
# 1. Do NOT put your Microsoft Client Secret here. That belongs in the Firebase Console.
# 2. Add 'localhost' and your Firebase Hosting domain to authorized domains in Firebase Console.

# App Check (see docs/appcheck-rollout-plan.md) — PLANNING placeholder, not yet
# wired into runtime. The reCAPTCHA site key is PUBLIC (safe to ship). The App
# Check *debug token* is NOT placed here — provide it per-machine/CI via env only.
VITE_FIREBASE_APPCHECK_SITE_KEY=your_recaptcha_site_key

# ──────────────────────────────────────────────────────────────────────────
# Authenticated smoke test (npm run smoke:auth) — PLACEHOLDERS ONLY.
# Put REAL values in your gitignored .env, never here.
# Use a DEDICATED test account (Email/Password provider) that has an ACTIVE
# DEFAULT_COMPANY membership — provision it with
# scripts/bootstrap-default-company-user.js. Never use a real owner account.
# ──────────────────────────────────────────────────────────────────────────
SMOKE_AUTH_EMAIL=smoke-test-user@example.com
SMOKE_AUTH_PASSWORD=your_test_account_password
# Optional — defaults to the live hosting URL when unset:
SMOKE_BASE_URL=https://florist-d5026.web.app
