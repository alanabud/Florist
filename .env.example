# Firebase Configuration
# These are public keys for the web client. Keep your Firebase secure using Firestore Rules, not by hiding these.
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Note:
# 1. Do NOT put your Microsoft Client Secret here. That belongs in the Firebase Console.
# 2. Add 'localhost' and your Firebase Hosting domain to authorized domains in Firebase Console.
